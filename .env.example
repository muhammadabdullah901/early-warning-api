# ── Example environment file ───────────────────────────────────────
# Copy this file and rename the copy to ".env", then fill in real values.
# The app reads these settings at startup (see app/config.py).

APP_NAME=Early Warning System API

# ERP connection. While ERP_MOCK_MODE=true the app uses fake data and
# does NOT call any real server. Switch to false once you have real
# ERP details from your team.
ERP_BASE_URL=https://erp.example.com/api
ERP_API_KEY=your-erp-api-key-here
ERP_MOCK_MODE=true
